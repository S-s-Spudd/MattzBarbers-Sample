---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  page?: string;
}

const {
  title       = 'Mattz Barbers | Barbershop in Sutton Coldfield',
  description = "Mattz Barbers — professional men's haircuts, skin fades and beard services in Walmley, Sutton Coldfield. Appointment only. Book online via Fresha.",
} = Astro.props;

const canonical = `https://mattz.co.uk${Astro.url.pathname}`;
---
<!doctype html>
<html lang="en-GB" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="keywords" content="barber sutton coldfield, barbershop walmley, skin fade sutton coldfield, haircut sutton coldfield, mattz barbers, taperfade birmingham, beard trim sutton coldfield" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1A1A1A" />
  <meta name="geo.region" content="GB-ENG" />
  <meta name="geo.placename" content="Sutton Coldfield" />

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:locale"      content="en_GB" />
  <meta property="og:site_name"   content="Mattz Barbers" />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "HairSalon",
    "name": "Mattz Barbers",
    "url": "https://mattz.co.uk",
    "telephone": "+447401132085",
    "email": "matt@mattz.co.uk",
    "priceRange": "£13–£27",
    "image": "https://mattz.co.uk/images/logo.webp",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "30A Walmley Road",
      "addressLocality": "Sutton Coldfield",
      "addressRegion": "West Midlands",
      "postalCode": "B76 1QN",
      "addressCountry": "GB"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 52.5413, "longitude": -1.8007 },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday"], "opens": "09:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Thursday","Friday"], "opens": "09:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "17:00" }
    ],
    "sameAs": [
      "https://www.instagram.com/mattzbarbers_/",
      "https://www.facebook.com/mattzbarbers/",
      "https://www.fresha.com/a/mattz-barbers-birmingham-the-royal-town-of-sutton-coldfield-30a-walmley-road-q138b6q6"
    ]
  }
  </script>

  <!-- Prevent theme flash — runs before paint -->
  <script is:inline>
    (function(){
      try{
        var s=localStorage.getItem('mattz-theme');
        var p=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',s||p);
      }catch(e){}
    })();
  </script>

  <title>{title}</title>
</head>

<body class="grain">
  <div class="page-body">
    <slot />
  </div>

  <!-- Scroll animations + Lenis (non-blocking module script) -->
  <script>
    import Lenis from 'lenis';
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const lenis = new Lenis({
      duration: 1.1,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      syncTouch: false,
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time: number) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    /* Nav frosted glass */
    const nav = document.getElementById('main-nav');
    ScrollTrigger.create({
      start: 60,
      onUpdate: (s) => nav?.classList.toggle('scrolled', s.scroll() > 60),
    });

    /* Scroll reveal */
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); } }),
      { threshold: 0.07, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    /* Hero parallax */
    const heroImg = document.querySelector<HTMLElement>('.parallax-img');
    if (heroImg) {
      gsap.to(heroImg, {
        yPercent: 14, ease: 'none',
        scrollTrigger: { trigger: heroImg.closest('section') || heroImg, start: 'top top', end: 'bottom top', scrub: 1.2 },
      });
    }

    /* Gallery word parallax */
    const gWord = document.querySelector<HTMLElement>('.gallery-bg-word');
    if (gWord) {
      gsap.to(gWord, {
        yPercent: -22, ease: 'none',
        scrollTrigger: { trigger: '#gallery', start: 'top bottom', end: 'bottom top', scrub: 1 },
      });
    }

    /* Polaroid entrance */
    document.querySelectorAll<HTMLElement>('.polaroid').forEach((c, i) => {
      gsap.from(c, {
        opacity: 0, y: 40, duration: 0.85, ease: 'power2.out',
        scrollTrigger: { trigger: c, start: 'top 94%' },
        delay: (i % 4) * 0.07,
      });
    });

    /* Service items */
    gsap.utils.toArray<HTMLElement>('.service-item').forEach((el, i) => {
      gsap.from(el, { opacity: 0, x: -10, duration: 0.5, ease: 'power2.out', scrollTrigger: { trigger: el, start: 'top 92%' }, delay: i * 0.035 });
    });

    /* Testimonial cards */
    gsap.utils.toArray<HTMLElement>('.testimonial-card').forEach((c, i) => {
      gsap.from(c, { opacity: 0, y: 24, duration: 0.7, ease: 'power2.out', scrollTrigger: { trigger: c, start: 'top 90%' }, delay: i * 0.08 });
    });

    /* Rating bars */
    document.querySelectorAll<HTMLElement>('.rating-bar-fill').forEach(bar => {
      gsap.from(bar, { scaleX: 0, duration: 1.1, ease: 'power3.out', scrollTrigger: { trigger: bar, start: 'top 88%' } });
    });

    /* Step cards */
    gsap.utils.toArray<HTMLElement>('.step-card').forEach((c, i) => {
      gsap.from(c, { opacity: 0, y: 18, duration: 0.65, ease: 'power2.out', scrollTrigger: { trigger: c, start: 'top 91%' }, delay: i * 0.1 });
    });

    /* Page link cards */
    gsap.utils.toArray<HTMLElement>('.page-link-card').forEach((c, i) => {
      gsap.from(c, { opacity: 0, y: 22, duration: 0.7, ease: 'power2.out', scrollTrigger: { trigger: c, start: 'top 91%' }, delay: i * 0.09 });
    });
  </script>
</body>
</html>
