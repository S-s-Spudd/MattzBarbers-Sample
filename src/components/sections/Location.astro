---
import MapEmbed from '../MapEmbed';

const hours = [
  { day: 'Monday',    time: '9:00 – 18:00', closed: false },
  { day: 'Tuesday',   time: '9:00 – 18:00', closed: false },
  { day: 'Wednesday', time: '9:00 – 18:00', closed: false },
  { day: 'Thursday',  time: '9:00 – 19:00', closed: false },
  { day: 'Friday',    time: '9:00 – 19:00', closed: false },
  { day: 'Saturday',  time: '9:00 – 17:00', closed: false },
  { day: 'Sunday',    time: 'Closed',        closed: true  },
];
const today = new Date().toLocaleDateString('en-GB', { weekday: 'long' });
const PX = 'px-[clamp(1.25rem,5vw,5rem)]';
---

<!-- Map + Info -->
<section class="relative py-20 md:py-28" style="background:var(--bg);" aria-label="Location">
  <div class="absolute inset-0 flex items-center overflow-hidden pointer-events-none select-none" aria-hidden="true">
    <span class="watermark translate-x-[30%] opacity-[0.03]">Walmley</span>
  </div>

  <div class={`relative z-10 max-w-[1600px] mx-auto ${PX}`}>
    <div class="mb-12">
      <p class="eyebrow mb-4 reveal">Location</p>
      <h2 class="font-display italic font-light leading-[0.9] text-[clamp(2rem,4vw,3.5rem)] text-[var(--text)] reveal reveal-delay-1">Find us in Walmley.</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] xl:grid-cols-[1fr_380px] gap-6 lg:gap-8 items-start">

      <!-- Map card -->
      <div class="border border-[var(--border)] overflow-hidden reveal">
        <!-- Header bar -->
        <div class="flex items-center justify-between px-4 py-3" style="background:var(--surface);border-bottom:1px solid var(--border);">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[var(--accent)]"></span>
            <p class="text-xs tracking-[0.16em] uppercase text-[var(--text-muted)]">Mattz Barbers · Walmley</p>
          </div>
          <a href="https://www.google.com/maps?q=52.5412615,-1.8006928"
             target="_blank" rel="noopener noreferrer"
             class="text-[0.62rem] tracking-[0.14em] uppercase text-[var(--accent)] hover:opacity-75 transition-opacity flex items-center gap-1">
            Open in Maps <span>↗</span>
          </a>
        </div>
        <!-- Lazy map -->
        <div style="height:clamp(320px,45vw,480px);">
          <MapEmbed client:visible />
        </div>
        <!-- Address strip -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-4 py-3" style="border-top:1px solid var(--border);background:var(--surface);">
          <address class="not-italic text-xs text-[var(--text-muted)] leading-snug">30A Walmley Road · Sutton Coldfield · West Midlands · B76 1QN</address>
          <a href="https://www.google.com/maps/dir/?api=1&destination=52.5412615,-1.8006928"
             target="_blank" rel="noopener noreferrer"
             class="btn-book flex-shrink-0" style="padding:0.55rem 1.1rem;font-size:0.66rem;">
            Get Directions
          </a>
        </div>
      </div>

      <!-- Right column: Hours + Info -->
      <div class="flex flex-col gap-5">
        <!-- Opening hours -->
        <div class="info-block reveal reveal-delay-1">
          <p class="eyebrow text-[0.6rem] mb-4 pb-3 border-b border-[var(--border)]">Opening Hours</p>
          <p class="text-[0.68rem] text-[var(--accent)] tracking-wide mb-3 uppercase" style="letter-spacing:0.14em;">Appointment Only</p>
          {hours.map(({ day, time, closed }) => (
            <div class="hours-row" style={day === today ? 'color:var(--text);font-weight:500;' : ''}>
              <div class="flex items-center gap-2">
                {day === today && <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:var(--accent);" aria-label="Today"></span>}
                <span>{day}</span>
              </div>
              <span style={closed ? 'color:var(--text-faint);' : day === today ? 'color:var(--accent);' : ''}>{time}</span>
            </div>
          ))}
        </div>

        <!-- Contact -->
        <div class="info-block reveal reveal-delay-2">
          <p class="eyebrow text-[0.6rem] mb-4 pb-3 border-b border-[var(--border)]">Contact</p>
          <div class="space-y-3">
            <a href="tel:+447401132085" class="flex items-center gap-3 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors group">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--accent)]">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.36 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              07401 132085
            </a>
            <a href="mailto:matt@mattz.co.uk" class="flex items-center gap-3 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--accent)]">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
              matt@mattz.co.uk
            </a>
            <a href="https://www.instagram.com/mattzbarbers_/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--accent)]">
                <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
              @mattzbarbers_
            </a>
            <a href="https://www.facebook.com/mattzbarbers/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--accent)]">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
              mattzbarbers
            </a>
          </div>
        </div>

        <!-- Getting here -->
        <div class="info-block reveal reveal-delay-3">
          <p class="eyebrow text-[0.6rem] mb-3">Getting Here</p>
          <div class="space-y-2 text-sm text-[var(--text-muted)] leading-relaxed">
            <p><span class="text-[var(--accent)] mr-1.5">🚌</span>Bus 97/97A stops on Walmley Road, 2 min walk.</p>
            <p><span class="text-[var(--accent)] mr-1.5">🚗</span>Free on-street parking on Walmley Road.</p>
            <p><span class="text-[var(--accent)] mr-1.5">🚶</span>5 min walk from Walmley village centre.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Form -->
<section class="relative py-20 md:py-28" style="background:var(--bg-alt);border-top:1px solid var(--border);" aria-label="Contact">
  <div class={`max-w-[1600px] mx-auto ${PX}`}>
    <div class="grid grid-cols-1 lg:grid-cols-[380px_1fr] gap-10 lg:gap-20">
      <div>
        <p class="eyebrow mb-4 reveal">Get in Touch</p>
        <h2 class="font-display italic font-light leading-[0.9] text-[clamp(2rem,4vw,3.5rem)] text-[var(--text)] reveal reveal-delay-1">Send us<br/>a message.</h2>
        <div class="hairline mt-6 mb-5 reveal reveal-delay-2"></div>
        <p class="text-[var(--text-muted)] text-sm leading-relaxed reveal reveal-delay-3">
          For general enquiries, drop us a message below. For bookings, please use Fresha.
        </p>
        <div class="mt-6 space-y-3 reveal reveal-delay-4">
          <a href="tel:+447401132085" class="flex items-center gap-2 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
            <span class="text-[var(--accent)]">T</span> 07401 132085
          </a>
          <a href="mailto:matt@mattz.co.uk" class="flex items-center gap-2 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
            <span class="text-[var(--accent)]">E</span> matt@mattz.co.uk
          </a>
        </div>
      </div>

      <!-- Form — uses Netlify Forms. For Cloudflare/Vercel use Formspree: action="https://formspree.io/f/YOUR_ID" -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        class="flex flex-col gap-4 reveal reveal-delay-2"
        aria-label="Contact form"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="cf-name" class="eyebrow text-[0.58rem] block mb-2">Name</label>
            <input id="cf-name" name="name" type="text" required placeholder="Your name" class="contact-field" />
          </div>
          <div>
            <label for="cf-email" class="eyebrow text-[0.58rem] block mb-2">Email</label>
            <input id="cf-email" name="email" type="email" required placeholder="your@email.com" class="contact-field" />
          </div>
        </div>

        <div>
          <label for="cf-phone" class="eyebrow text-[0.58rem] block mb-2">Phone (optional)</label>
          <input id="cf-phone" name="phone" type="tel" placeholder="07xxx xxxxxx" class="contact-field" />
        </div>

        <div>
          <label for="cf-message" class="eyebrow text-[0.58rem] block mb-2">Message</label>
          <textarea id="cf-message" name="message" required rows="5" placeholder="How can we help?" class="contact-field resize-none"></textarea>
        </div>

        <div class="flex items-center gap-4 flex-wrap">
          <button type="submit" class="btn-book">Send Message</button>
          <p class="text-[0.68rem] text-[var(--text-faint)]">We aim to reply within 24 hours.</p>
        </div>
      </form>
    </div>
  </div>
</section>
