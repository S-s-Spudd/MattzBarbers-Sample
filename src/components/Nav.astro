---
import ThemeToggle from './ThemeToggle';

const { pathname } = Astro.url;
const isActive = (p: string) => p === '/' ? pathname === '/' : pathname.startsWith(p);

const links = [
  { href: '/',         label: 'Home'     },
  { href: '/services', label: 'Services' },
  { href: '/reviews',  label: 'Reviews'  },
  { href: '/find-us',  label: 'Find Us'  },
];
---

<!-- Mobile overlay -->
<div id="mobile-overlay" aria-hidden="true" role="dialog">
  <div class="flex flex-col justify-center" style="min-height:100%;">
    <a href="/" class="mb-10 inline-block">
      <img src="/images/logo.webp" alt="Mattz Barbers" class="logo-img" style="height:44px;" width="1600" height="558" decoding="async" />
    </a>

    <nav class="flex flex-col gap-1">
      {links.map(({ href, label }) => (
        <a href={href} class:list={['mobile-nav-link font-display italic transition-colors duration-200 py-2',
          'text-[clamp(2.4rem,7vw,4.5rem)] leading-tight',
          isActive(href) ? 'text-[var(--accent)]' : 'text-[var(--text)] hover:text-[var(--accent)]'
        ]}>
          {label}
        </a>
      ))}
    </nav>

    <div class="mt-10 flex flex-col gap-4">
      <a href="https://www.fresha.com/a/mattz-barbers-birmingham-the-royal-town-of-sutton-coldfield-30a-walmley-road-q138b6q6/booking?allOffer=true&pId=1394571"
         target="_blank" rel="noopener noreferrer" class="btn-book self-start">
        Book Now
      </a>
      <div class="flex items-center gap-4 mt-2">
        <!-- Instagram -->
        <a href="https://www.instagram.com/mattzbarbers_/" target="_blank" rel="noopener noreferrer"
           aria-label="Instagram" class="social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a href="https://www.facebook.com/mattzbarbers/" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook" class="social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      </div>
      <p class="text-xs text-[var(--text-faint)] tracking-wide mt-2">07401 132085</p>
    </div>
  </div>
</div>

<!-- Nav bar -->
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between"
     style="padding: clamp(0.9rem,2.2vw,1.4rem) clamp(1rem,4vw,2.5rem);"
     aria-label="Main navigation">

  <!-- Logo -->
  <a href="/" aria-label="Mattz Barbers — home" class="relative z-50 flex-shrink-0">
    <img src="/images/logo.webp" alt="Mattz Barbers" class="logo-img hover:opacity-75 transition-opacity" width="1600" height="558" decoding="async" fetchpriority="high" />
  </a>

  <!-- Desktop links -->
  <div class="hidden md:flex items-center gap-6 lg:gap-8">
    {links.map(({ href, label }) => (
      <a href={href} class:list={['nav-link text-[0.72rem] tracking-[0.2em] uppercase transition-colors duration-200',
        isActive(href) ? 'active text-[var(--accent)]' : 'text-[var(--text-muted)] hover:text-[var(--accent)]'
      ]}>
        {label}
      </a>
    ))}

    <div class="w-px h-4" style="background:var(--border);"></div>

    <!-- Social icons desktop -->
    <a href="https://www.instagram.com/mattzbarbers_/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link" style="min-width:unset;min-height:unset;width:20px;height:20px;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
    </a>
    <a href="https://www.facebook.com/mattzbarbers/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link" style="min-width:unset;min-height:unset;width:20px;height:20px;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
    </a>

    <div class="w-px h-4" style="background:var(--border);"></div>
    <ThemeToggle client:load />

    <a href="https://www.fresha.com/a/mattz-barbers-birmingham-the-royal-town-of-sutton-coldfield-30a-walmley-road-q138b6q6/booking?allOffer=true&pId=1394571"
       target="_blank" rel="noopener noreferrer" class="btn-book" style="padding:0.7rem 1.5rem;">
      Book Now
    </a>
  </div>

  <!-- Mobile controls -->
  <div class="flex md:hidden items-center gap-3 z-50">
    <ThemeToggle client:load />
    <button id="menu-btn" type="button" aria-label="Toggle menu" aria-expanded="false"
            class="flex flex-col gap-[5px] p-2 -mr-1">
      <span class="burger-line block w-6 h-[1.5px] bg-[var(--text)] origin-center transition-all duration-300"></span>
      <span class="burger-line block w-6 h-[1.5px] bg-[var(--text)] origin-center transition-all duration-300"></span>
      <span class="burger-line block w-4 h-[1.5px] bg-[var(--text)] origin-center transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- ── Hamburger: inline script so it runs regardless of GSAP ── -->
<script is:inline>
(function () {
  var open = false;

  function init() {
    var btn     = document.getElementById('menu-btn');
    var overlay = document.getElementById('mobile-overlay');
    var nav = document.getElementById('main-nav');
    if (!btn || !overlay || !nav) return;

    function setOpen(val) {
      open = val;
      overlay.classList.toggle('open', open);
      nav.classList.toggle('menu-open', open);
      document.body.classList.toggle('menu-open', open);
      overlay.setAttribute('aria-hidden', String(!open));
      btn.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';

      var lines = btn.querySelectorAll('.burger-line');
      if (open) {
        lines[0].style.transform = 'translateY(6.5px) rotate(45deg)';
        lines[1].style.opacity   = '0';
        lines[2].style.transform = 'translateY(-6.5px) rotate(-45deg)';
      } else {
        lines[0].style.transform = '';
        lines[1].style.opacity   = '';
        lines[2].style.transform = '';
      }
    }

    btn.addEventListener('click', function () { setOpen(!open); });

    document.querySelectorAll('.mobile-nav-link').forEach(function (l) {
      l.addEventListener('click', function () { setOpen(false); });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && open) setOpen(false);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
